# ============================================================
# VARIÁVEIS DE FRONTEND (build time - Vite)
# ============================================================
# Estas são as ÚNICAS variáveis necessárias para buildar o frontend.
# Elas são públicas (vão no bundle JS) - NUNCA coloque secrets aqui.

VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-publica-aqui"
VITE_SUPABASE_PROJECT_ID="seu-project-id"

# ============================================================
# SECRETS DE BACKEND (Edge Functions Supabase)
# ============================================================
# IMPORTANTE: Estas variáveis NÃO vão neste arquivo .env nem na VPS.
# Elas devem ser configuradas no painel Supabase em:
#   Project Settings > Edge Functions > Manage secrets
#
# Ou via CLI:
#   supabase secrets set NOME=valor --project-ref SEU_PROJETO
#
# As Edge Functions rodam na infraestrutura Supabase, não na sua VPS.
# A VPS serve apenas o frontend estático (SPA React + Vite).
#
# Lista de secrets obrigatórios no Supabase:
#
#   SUPABASE_URL                    (auto-injetado)
#   SUPABASE_ANON_KEY               (auto-injetado)
#   SUPABASE_SERVICE_ROLE_KEY       (auto-injetado)
#   SUPABASE_DB_URL                 (auto-injetado)
#
#   RESEND_API_KEY                  (e-mails transacionais)
#   LOVABLE_API_KEY                 (Lovable AI Gateway - opcional)
#
#   MP_WEBHOOK_SECRET               (validação HMAC do webhook Mercado Pago)
#
# Tokens de gateways (Mercado Pago, Pagar.me, PagBank, Asaas) e
# credenciais Melhor Envio NÃO ficam em secrets - são salvos
# dinamicamente na tabela `site_settings` via painel /admin/configuracoes.
#
# ============================================================
# DEPLOY VPS (opcional - apenas para scripts deploy-vps/)
# ============================================================

# Domínio público da loja (sem https://)
SERVER_NAME="loja.seudominio.com"

# E-mail para emissão de SSL Let's Encrypt
SSL_EMAIL="admin@seudominio.com"