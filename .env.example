# =============================================================================
# .env.example — Template completo
# Copie para `.env` e preencha. Rode `bash deploy-vps/validate-env.sh` antes
# de qualquer deploy para garantir que nada está faltando.
# =============================================================================

# -----------------------------------------------------------------------------
# [1] FRONTEND (build time — Vite)
# -----------------------------------------------------------------------------
# Variáveis públicas (vão no bundle JS). NUNCA coloque secrets aqui.
# Obrigatórias para `npm run build` funcionar.

VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi...sua-anon-key-publica"
VITE_SUPABASE_PROJECT_ID="seu-project-ref"

# -----------------------------------------------------------------------------
# [2] DEPLOY VPS (Nginx + Docker + SSL)
# -----------------------------------------------------------------------------
# Usadas pelos scripts em deploy-vps/ (install.sh, issue-ssl.sh, entrypoint).

# Domínio público da loja (sem https://, sem barra final)
SERVER_NAME="loja.seudominio.com"

# E-mail para emissão de SSL Let's Encrypt
SSL_EMAIL="admin@seudominio.com"

# Host Supabase usado pelo Nginx para proxiar /api e webhooks (auto-derivado de
# VITE_SUPABASE_URL se vazio). Ex.: vkomfiplmhpkhfpidrng.supabase.co
SUPABASE_PROXY_HOST=""

# Base URL completa das Edge Functions (auto-derivada se vazia).
# Ex.: https://vkomfiplmhpkhfpidrng.supabase.co/functions/v1
SUPABASE_FUNCTIONS_BASE_URL=""

# -----------------------------------------------------------------------------
# [3] DEPLOY DAS EDGE FUNCTIONS (Supabase CLI)
# -----------------------------------------------------------------------------
# Usado por deploy-vps/deploy-supabase-functions.sh

SUPABASE_PROJECT_REF="seu-project-ref"

# Token de acesso da CLI (https://supabase.com/dashboard/account/tokens)
# Necessário apenas em CI/CD não-interativo. Localmente use `supabase login`.
SUPABASE_ACCESS_TOKEN=""

# =============================================================================
# [4] SECRETS DAS EDGE FUNCTIONS — NÃO PREENCHER AQUI
# =============================================================================
# Os valores abaixo NÃO vão neste arquivo nem na VPS. Eles devem ser
# configurados como secrets no Supabase:
#
#   supabase secrets set NOME=valor --project-ref $SUPABASE_PROJECT_REF
#
# Ou via Dashboard: Project Settings → Edge Functions → Manage secrets.
#
# Lista obrigatória:
#   SUPABASE_URL                  (auto-injetado pelo Supabase)
#   SUPABASE_ANON_KEY             (auto-injetado)
#   SUPABASE_SERVICE_ROLE_KEY     (auto-injetado)
#   SUPABASE_DB_URL               (auto-injetado)
#   RESEND_API_KEY                (e-mails transacionais)
#   MP_WEBHOOK_SECRET             (HMAC do webhook Mercado Pago)
#
# Lista opcional:
#   LOVABLE_API_KEY               (Lovable AI Gateway, se usado)
#
# Tokens de gateways (Mercado Pago, Pagar.me, PagBank, Asaas) e credenciais
# do Melhor Envio NÃO ficam em secrets — são salvos dinamicamente na tabela
# `site_settings` via painel /admin/configuracoes.
# =============================================================================
